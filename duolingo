   ============================================================ */
const $=id=>document.getElementById(id);
function shuffle(a){a=a.slice();for(let i=a.length-1;i>0;i--){const j=Math.random()*(i+1)|0;[a[i],a[j]]=[a[j],a[i]];}return a;}
function show(s){document.querySelectorAll('.screen').forEach(x=>x.classList.remove('active'));$(s).classList.add('active');window.scrollTo(0,0);}
function updateTop(){ $('h-streak').textContent=state.streak; $('h-gems').textContent=state.gems; $('h-hearts').textContent=state.hearts; }
function today(){ return new Date().toISOString().slice(0,10); }

/* ============================================================
   HOME / PAD
   ============================================================ */
function renderHome(){
  regenHearts(); save(); updateTop();
  const cont=$('units'); cont.innerHTML='';

  // dagelijkse herhaalkaart bovenaan
  const wc=weakCount(); const reviewedToday=state.lastReviewDate===today();
  const rc=document.createElement('button');
  rc.className='review-card'+(reviewedToday?' done':'');
  const rsub = reviewedToday ? 'Vandaag gedaan ✅ — nog een rondje?'
             : (wc>0 ? (wc+' woord'+(wc>1?'en':'')+' om te herhalen') : 'Frissen je geleerde woorden op');
  rc.innerHTML=`<div class="ricon">${reviewedToday?'🔁':'🎯'}</div>
    <div class="rtext"><h2>Dagelijkse herhaling</h2><p>${rsub}</p></div>
    <div class="rarrow">▶</div>`;
  rc.onclick=startReview;
  cont.appendChild(rc);

  UNITS.forEach((u,ui)=>{
    const done=state.progress[ui]||0;
    const prevDone=ui===0?LESSONS_PER_UNIT:(state.progress[ui-1]||0);
    const unlocked = ui===0 || prevDone>=LESSONS_PER_UNIT;

    const banner=document.createElement('div');
    banner.className='unit-banner'+(unlocked?'':' locked');
    banner.style.background=u.color;
    const parts=u.title.split('·');
    banner.innerHTML=`<div><h2>${parts[0].trim()}</h2><p>${parts[1].trim()}</p>
      <div class="sub">${unlocked?(done+'/'+LESSONS_PER_UNIT+' lessen'):'🔒 Rond de vorige unit af'}</div></div>
      <div class="guide">${u.guide}</div>`;
    cont.appendChild(banner);

    const path=document.createElement('div'); path.className='path';
    for(let li=0; li<LESSONS_PER_UNIT; li++){
      const row=document.createElement('div'); row.className='lesson-row';
      let cls='locked', ico='🔒';
      if(unlocked && li<done){cls='done';ico='⭐';}
      else if(unlocked && li===done){cls='current';ico='★';}
      const node=document.createElement('button');
      node.className='node '+cls;
      node.style.transform=`translateX(${Math.round(Math.sin(li*0.6)*72)}px)`;
      node.innerHTML=(cls==='current'?'<span class="start-pill">START</span>':'')+ico+`<span class="lbl">Les ${li+1}</span>`;
      if(cls!=='locked') node.onclick=()=>startLesson(ui,li);
      row.appendChild(node); path.appendChild(row);
    }
    cont.appendChild(path);
  });
}

/* ============================================================
   LES-GENERATOR  (30 per unit, schuivend focusvenster)
   ============================================================ */
function startLesson(ui,li){
  regenHearts();
  if(state.hearts<=0){ $('heartModal').classList.add('active'); return; }
  const unit=UNITS[ui];
  session={ui,li,unit,queue:buildLesson(unit,li),idx:0,correct:0,total:0,xp:0,answered:false};
  show('lesson'); updateTop(); $('l-hearts').textContent=state.hearts;
  renderQuestion();
}
function buildLesson(unit,li){
  const W=unit.words.length, win=Math.min(8,W);
  const maxStart=Math.max(0,W-win);
  const start=Math.round((li/(LESSONS_PER_UNIT-1))*maxStart);
  const focus=unit.words.slice(start,start+win);
  const fw=shuffle(focus);
  const S=shuffle(unit.sentences);
  const pool=unit.words;
  const q=[
    makeMC(fw[0%fw.length],pool),
    makeMC(fw[1%fw.length],pool),
    makeListen(fw[2%fw.length]),
    makeMatch(shuffle(focus).slice(0,4)),
    makeTranslate(S[0%S.length],pool),
    makeMC(fw[3%fw.length],pool),
    makeTranslate(S[1%S.length],pool),
  ];
  return shuffle(q);
}
function makeMC(word,pool){ const opts=shuffle([word,...shuffle(pool.filter(w=>w!==word && w.nl!==word.nl)).slice(0,3)]); return {type:'mc',word,opts,answer:word.nl,key:word.key}; }
function makeListen(word){ return {type:'listen',word,answer:word.es,key:word.key}; }
function makeMatch(words){ return {type:'match',words}; }
function makeTranslate(sent,pool){
  const extra=shuffle(pool.map(w=>w.es).concat(['el','la','y','un','en']))
    .filter(w=>!sent.es.includes(w)).slice(0,3);
  return {type:'translate',sent,bank:shuffle(sent.es.concat(extra))};
}

/* ---- foutentracking: woorden waar je fout op maakt ---- */
function recordWord(key,correct){
  if(!key)return; if(!state.weak)state.weak={};
  if(correct){ if(state.weak[key]){ state.weak[key]--; if(state.weak[key]<=0) delete state.weak[key]; } }
  else { state.weak[key]=Math.min(5,(state.weak[key]||0)+1); }
  save();
}
function weakCount(){ return Object.values(state.weak||{}).filter(v=>v>0).length; }

/* ---- dagelijkse herhaalles uit je zwakke woorden ---- */
function buildReview(){
  const pool=ALLWORDS;
  let keys=Object.keys(state.weak||{}).filter(k=>state.weak[k]>0 && WORDMAP[k]);
  keys.sort((a,b)=>state.weak[b]-state.weak[a]);
  let words=keys.map(k=>WORDMAP[k]);
  if(words.length<6){
    const started=[]; UNITS.forEach((u,ui)=>{ if(ui===0||(state.progress[ui]||0)>0) started.push(...u.words); });
    const src=started.length?started:ALLWORDS;
    words=words.concat(shuffle(src).filter(w=>!words.includes(w))).slice(0,6);
  } else { words=words.slice(0,8); }
  const focus=shuffle(words).slice(0,6);
  const q=[];
  focus.forEach((w,i)=>{ q.push((i%2===1)?makeListen(w):makeMC(w,pool)); });
  if(focus.length>=4) q.push(makeMatch(shuffle(focus).slice(0,4)));
  for(const w of focus){ const sent=UNITS[w.ui].sentences.find(se=>se.es.includes(w.es)); if(sent){ q.push(makeTranslate(sent,pool)); break; } }
  return shuffle(q);
}
function startReview(){
  regenHearts();
  if(state.hearts<=0){ $('heartModal').classList.add('active'); return; }
  const q=buildReview(); if(!q.length) return;
  session={review:true,unit:UNITS[0],queue:q,idx:0,correct:0,total:0,xp:0,answered:false};
  show('lesson'); updateTop(); $('l-hearts').textContent=state.hearts; renderQuestion();
}

/* ============================================================
   VRAAG RENDEREN
   ============================================================ */
let session=null;
function renderQuestion(){
  const s=session, q=s.queue[s.idx];
  s.answered=false; s.picked=null; s.built=[];
  $('l-progress').style.width=(s.idx/s.queue.length*100)+'%';
  const f=$('l-footer'); f.className='footer'; $('l-feedback').innerHTML='';
  const chk=$('l-check'); chk.textContent='Controleer'; chk.className='btn btn-gray'; chk.disabled=true; chk.onclick=onCheck;
  const body=$('l-body');

  if(q.type==='mc'){
    body.innerHTML=`<div class="prompt-title">Wat betekent dit woord?</div>
      <div class="speaker-row"><button class="speaker-btn" onclick="speak('${q.word.es.replace(/'/g,"\\'")}')">🔊</button><div class="es-word">${q.word.es}</div></div>
      <div class="choice-grid" id="grid"></div>`;
    const grid=$('grid');
    q.opts.forEach((o,i)=>{
      const b=document.createElement('button'); b.className='choice'; b.dataset.nl=o.nl; b.dataset.correct=(o.nl===q.answer)?'1':'';
      b.innerHTML=`<span class="num">${i+1}</span><span class="emoji">${o.emoji}</span>${o.nl}`;
      b.onclick=()=>{document.querySelectorAll('#grid .choice').forEach(c=>c.classList.remove('selected'));b.classList.add('selected');s.picked=o;enableCheck();};
      grid.appendChild(b);
    });
    speak(q.word.es);
  }
  else if(q.type==='listen'){
    body.innerHTML=`<div class="prompt-title">Typ wat je hoort</div>
      <div class="speaker-row"><button class="speaker-btn" onclick="speak('${q.word.es.replace(/'/g,"\\'")}')">🔊</button><button class="speaker-btn small" onclick="speak('${q.word.es.replace(/'/g,"\\'")}')">🐢</button></div>
      <input class="type-input" id="typed" placeholder="Typ het Spaanse woord..." autocomplete="off" autocapitalize="off" spellcheck="false">
      <p style="font-weight:700;color:#afafaf;margin-top:12px;font-size:14px">Tip: het betekent "${q.word.nl}"</p>`;
    const inp=$('typed'); inp.oninput=()=>{s.picked=inp.value;inp.value.trim()?enableCheck():disableCheck();};
    inp.onkeydown=e=>{if(e.key==='Enter'&&!$('l-check').disabled)onCheck();};
    setTimeout(()=>{inp.focus();speak(q.word.es);},250);
  }
  else if(q.type==='match'){
    const left=q.words, right=shuffle(q.words);
    s.matchState={sel:null,doneCount:0,need:q.words.length};
    body.innerHTML=`<div class="prompt-title">Verbind de paren 🔗</div><div class="match-cols"><div id="col-es"></div><div id="col-nl"></div></div>`;
    const ce=$('col-es'), cn=$('col-nl');
    [ce,cn].forEach(c=>{c.style.display='flex';c.style.flexDirection='column';c.style.gap='13px';});
    left.forEach(w=>{const b=document.createElement('button');b.className='match-btn';b.textContent=w.es;b.dataset.key=w.es;b.dataset.wkey=w.key||'';b.dataset.side='es';b.onclick=()=>{speak(w.es);pickMatch(b,w.es);};ce.appendChild(b);});
    right.forEach(w=>{const b=document.createElement('button');b.className='match-btn';b.textContent=w.nl;b.dataset.key=w.es;b.dataset.wkey=w.key||'';b.dataset.side='nl';b.onclick=()=>pickMatch(b,w.es);cn.appendChild(b);});
    $('l-check').textContent='Verbind alle paren';
  }
  else if(q.type==='translate'){
    body.innerHTML=`<div class="prompt-title">Vertaal naar het Spaans 🇪🇸</div>
      <div class="speaker-row"><div class="guide" style="font-size:44px">${s.unit.guide}</div><div class="es-word">${q.sent.nl}</div></div>
      <div class="answer-area" id="ans"></div><div class="bank" id="bank"></div>`;
    const bank=$('bank'), ans=$('ans');
    q.bank.forEach((w,i)=>{
      const t=document.createElement('button'); t.className='tile'; t.textContent=w; t.dataset.i=i;
      t.onclick=()=>{ const mv=document.createElement('button'); mv.className='tile'; mv.textContent=w;
        mv.onclick=()=>{mv.remove();t.classList.remove('used');s.built=s.built.filter(x=>x.i!==i);syncTrans();};
        ans.appendChild(mv); t.classList.add('used'); s.built.push({i,w}); syncTrans(); };
      bank.appendChild(t);
    });
  }
}
function syncTrans(){ session.built.length?enableCheck():disableCheck(); }
function enableCheck(){const c=$('l-check');c.disabled=false;c.className='btn btn-green';}
function disableCheck(){const c=$('l-check');c.disabled=true;c.className='btn btn-gray';}

/* matching (auto-check) */
function pickMatch(btn,key){
  const ms=session.matchState;
  if(btn.classList.contains('done'))return;
  if(!ms.sel){ms.sel=btn;btn.classList.add('selected');return;}
  if(ms.sel===btn){btn.classList.remove('selected');ms.sel=null;return;}
  if(ms.sel.dataset.side===btn.dataset.side){ms.sel.classList.remove('selected');ms.sel=btn;btn.classList.add('selected');return;}
  if(ms.sel.dataset.key===key){
    recordWord(btn.dataset.wkey,true);
    ms.sel.classList.remove('selected');ms.sel.classList.add('done');btn.classList.add('done');ms.sel=null;ms.doneCount++;
    if(ms.doneCount>=ms.need) finishQuestion(true,null);
  } else {
    recordWord(ms.sel.dataset.wkey,false); recordWord(btn.dataset.wkey,false);
    const a=ms.sel,b=btn; a.classList.add('flash-wrong');b.classList.add('flash-wrong');
    setTimeout(()=>{a.classList.remove('flash-wrong','selected');b.classList.remove('flash-wrong');},600);
    ms.sel=null; loseHeart();
  }
}

/* check */
function onCheck(){
  const s=session, q=s.queue[s.idx];
  if(s.answered){ nextQuestion(); return; }
  let correct=false, solution='';
  if(q.type==='mc'){
    correct = s.picked && s.picked.nl===q.answer; solution=q.answer;
    document.querySelectorAll('#grid .choice').forEach(c=>{c.classList.add('disabled');
      if(c.dataset.correct==='1')c.classList.add('correct');
      else if(c.classList.contains('selected'))c.classList.add('wrong');});
  }
  else if(q.type==='listen'){
    const norm=x=>x.toLowerCase().trim().replace(/[¿?¡!.,]/g,'');
    correct=norm(s.picked||'')===norm(q.answer); solution=q.answer;
  }
  else if(q.type==='translate'){
    correct=s.built.map(x=>x.w).join(' ')===q.sent.es.join(' '); solution=q.sent.es.join(' ');
  }
  if((q.type==='mc'||q.type==='listen') && q.key) recordWord(q.key,correct);
  finishQuestion(correct,solution);
}

function finishQuestion(correct,solution){
  const s=session, cq=s.queue[s.idx];
  if(cq.type==='translate') speak(cq.sent.es.join(' '));
  else if(cq.type==='listen') speak(cq.word.es);
  s.answered=true; s.total++;
  const f=$('l-footer'), fb=$('l-feedback'), chk=$('l-check');
  if(correct){
    s.correct++; s.xp+=10; if(navigator.vibrate)navigator.vibrate(20);
    f.className='footer correct';
    fb.innerHTML=`<div class="feedback correct"><div class="fico">✅</div><div>¡Muy bien! Goed zo!</div></div>`;
    chk.textContent='Verder'; chk.className='btn btn-green'; chk.disabled=false;
  }else{
    loseHeart(); f.className='footer wrong';
    const sol=solution?`<small>Juiste antwoord: ${solution}</small>`:'';
    fb.innerHTML=`<div class="feedback wrong"><div class="fico">❌</div><div>Bijna! ${sol}</div></div>`;
    chk.textContent='Verder'; chk.className='btn btn-red'; chk.disabled=false;
  }
  chk.onclick=()=>nextQuestion();
}

function loseHeart(){
  state.hearts=Math.max(0,state.hearts-1);
  if(state.hearts<5 && !state.lastHeartTs) state.lastHeartTs=Date.now();
  save();
  $('l-hearts').textContent=state.hearts; $('h-hearts').textContent=state.hearts;
  if(state.hearts<=0) setTimeout(()=>$('heartModal').classList.add('active'),400);
}

function nextQuestion(){
  const s=session;
  if(state.hearts<=0){ $('heartModal').classList.add('active'); return; }
  s.idx++;
  if(s.idx>=s.queue.length){ completeLesson(); return; }
  renderQuestion();
}

function completeLesson(){
  const s=session; $('l-progress').style.width='100%';
  state.gems+=20; state.totalXp+=s.xp;
  if(s.review) state.lastReviewDate=today();
  else state.progress[s.ui]=Math.max(state.progress[s.ui]||0, s.li+1);
  const t=today();
  if(state.lastActiveDate!==t){
    const y=new Date(Date.now()-86400000).toISOString().slice(0,10);
    state.streak=(state.lastActiveDate===y)?state.streak+1:1;
    state.lastActiveDate=t;
  }
  save();
  const acc=Math.round(s.correct/Math.max(1,s.total)*100);
  $('d-xp').textContent=s.xp; $('d-acc').textContent=acc+'%';
  updateTop(); show('done');
}

/* ============================================================
   NAVIGATIE / MODALS
   ============================================================ */
function quitLesson(){ $('heartModal').classList.remove('active'); session=null; renderHome(); show('home'); }
function backHome(){ renderHome(); show('home'); }
function refillHearts(){ state.hearts=5; state.lastHeartTs=null; save(); $('heartModal').classList.remove('active'); updateTop(); $('l-hearts').textContent=5; if(session)renderQuestion(); }
function openReset(){
  let n=0; Object.values(state.progress).forEach(v=>n+=v);
  $('reset-stats').innerHTML=`🔥 ${state.streak} dagen streak &nbsp;·&nbsp; ⚡ ${state.totalXp} XP &nbsp;·&nbsp; ✅ ${n} lessen gedaan`;
  $('resetModal').classList.add('active');
}
function closeReset(){ $('resetModal').classList.remove('active'); }
function resetAll(){ state={streak:0,gems:0,hearts:5,lastHeartTs:null,lastActiveDate:null,progress:{},totalXp:0,weak:{},lastReviewDate:null}; save(); closeReset(); renderHome(); }

/* ============================================================
   INIT
   ============================================================ */
load(); regenHearts(); renderHome();
</script>
</body>
</html>
