function parseWords(s){return s.trim().split('\n').map(l=>{const p=l.split('|');return{es:p[0].trim(),nl:p[1].trim(),emoji:(p[2]||'⭐').trim()};});}
function parseSents(s){return s.trim().split('\n').map(l=>{const p=l.split('=');return{es:p[0].trim().split(/\s+/),nl:p[1].trim()};});}
const UNITS = RAW.map(u=>({title:u.t,color:u.c,guide:u.g,words:parseWords(u.w),sentences:parseSents(u.s)}));
UNITS.forEach((u,ui)=>u.words.forEach(w=>{ w.ui=ui; w.key=ui+'|'+w.es; }));
const ALLWORDS = UNITS.flatMap(u=>u.words);
const WORDMAP = {}; ALLWORDS.forEach(w=>WORDMAP[w.key]=w);
const LESSONS_PER_UNIT = 30;

/* ============================================================
   STATE  +  PERSISTENTIE (localStorage, met veilige fallback)
   ============================================================ */
let state = { streak:0, gems:0, hearts:5, lastHeartTs:null, lastActiveDate:null, progress:{}, totalXp:0, weak:{}, lastReviewDate:null };
const SKEY = 'espanol_leren_v2';
function save(){ try{ localStorage.setItem(SKEY, JSON.stringify(state)); }catch(e){} }
function load(){ try{ const r=localStorage.getItem(SKEY); if(r){ const d=JSON.parse(r); state=Object.assign(state,d); } }catch(e){} }

const REGEN_MS = 30*60*1000;
function regenHearts(){
  if(state.hearts>=5){ state.lastHeartTs=null; return; }
  if(!state.lastHeartTs){ state.lastHeartTs=Date.now(); return; }
  const g=Math.floor((Date.now()-state.lastHeartTs)/REGEN_MS);
  if(g>0){ state.hearts=Math.min(5,state.hearts+g); state.lastHeartTs = state.hearts>=5?null:state.lastHeartTs+g*REGEN_MS; }
}

/* ============================================================
   AUDIO (Spaanse browserstem)
   ============================================================ */
let esVoice=null;
function pickVoice(){ const vs=speechSynthesis.getVoices(); esVoice=vs.find(v=>/es[-_]ES/i.test(v.lang))||vs.find(v=>/^es/i.test(v.lang))||null; }
if('speechSynthesis' in window){ pickVoice(); speechSynthesis.onvoiceschanged=pickVoice; }
function speak(t){ if(!('speechSynthesis' in window))return; speechSynthesis.cancel(); const u=new SpeechSynthesisUtterance(t); u.lang='es-ES'; u.rate=.9; if(esVoice)u.voice=esVoice; speechSynthesis.speak(u); }

