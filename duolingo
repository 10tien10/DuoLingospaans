<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Español — Leer Spaans</title>
<style>
  :root{
    --green:#58cc02; --green-dark:#58a700; --green-light:#d7ffb8;
    --blue:#1cb0f6; --blue-dark:#1899d6;
    --red:#ff4b4b; --red-dark:#ea2b2b;
    --yellow:#ffc800; --purple:#ce82ff;
    --gray:#e5e5e5; --gray-mid:#afafaf; --gray-dark:#4b4b4b;
    --text:#3c3c3c;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  body{
    font-family:'Nunito','Segoe UI',system-ui,-apple-system,sans-serif;
    background:#fff;color:var(--text);
    display:flex;justify-content:center;min-height:100vh;font-weight:800;
  }
  #app{width:100%;max-width:460px;min-height:100vh;position:relative;display:flex;flex-direction:column;background:#fff;}

  .topbar{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;gap:8px;position:sticky;top:0;background:#fff;z-index:5;}
  .stat{display:flex;align-items:center;gap:5px;font-size:18px;font-weight:800;}
  .stat .icon{font-size:21px;}
  .stat.streak{color:#ff9600;} .stat.gems{color:var(--blue);} .stat.hearts{color:var(--red);}
  .menu-btn{background:none;border:none;font-size:22px;cursor:pointer;color:var(--gray-mid);}

  .progress-wrap{display:flex;align-items:center;gap:14px;padding:8px 18px 4px;}
  .close-btn{background:none;border:none;font-size:30px;color:var(--gray-mid);cursor:pointer;line-height:1;font-weight:800;}
  .progress-bar{flex:1;height:16px;background:var(--gray);border-radius:10px;overflow:hidden;}
  .progress-fill{height:100%;background:var(--green);border-radius:10px;width:0;transition:width .4s ease;position:relative;}
  .progress-fill::after{content:"";position:absolute;top:3px;left:8px;right:8px;height:4px;background:rgba(255,255,255,.35);border-radius:4px;}

  .screen{flex:1;display:none;flex-direction:column;}
  .screen.active{display:flex;}

  .home-header{padding:16px 18px 6px;}
  .home-header h1{font-size:25px;color:var(--gray-dark);}
  .home-header p{font-size:14px;color:var(--gray-mid);font-weight:700;margin-top:2px;}
  .unit-banner{margin:16px 18px 6px;padding:16px 20px;border-radius:16px;color:#fff;display:flex;justify-content:space-between;align-items:center;box-shadow:0 4px 0 rgba(0,0,0,.15);}
  .unit-banner.locked{filter:grayscale(.7);opacity:.65;}
  .unit-banner h2{font-size:13px;text-transform:uppercase;letter-spacing:.5px;opacity:.85;}
  .unit-banner p{font-size:19px;margin-top:2px;}
  .unit-banner .sub{font-size:12px;font-weight:700;opacity:.85;margin-top:3px;}
  .guide{font-size:34px;}
  .review-card{width:calc(100% - 36px);margin:14px 18px 2px;padding:15px 18px;border:none;border-radius:16px;cursor:pointer;display:flex;align-items:center;gap:14px;text-align:left;color:#fff;font-family:inherit;background:linear-gradient(135deg,#ffb400,#ff7a00);box-shadow:0 4px 0 rgba(0,0,0,.15);}
  .review-card.done{background:linear-gradient(135deg,#9b8cff,#6f5cff);}
  .review-card:active{transform:translateY(2px);box-shadow:0 2px 0 rgba(0,0,0,.15);}
  .review-card .ricon{font-size:31px;}
  .review-card .rtext{flex:1;}
  .review-card h2{font-size:17px;}
  .review-card p{font-size:12px;font-weight:700;opacity:.92;margin-top:2px;}
  .review-card .rarrow{font-size:15px;opacity:.85;}
  .path{display:flex;flex-direction:column;align-items:center;gap:10px;padding:14px 0 26px;}
  .lesson-row{display:flex;justify-content:center;width:100%;}
  .node{width:70px;height:62px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:27px;position:relative;color:#fff;transition:transform .1s;}
  .node:active{transform:translateY(3px);}
  .node.done{background:var(--green);box-shadow:0 5px 0 var(--green-dark);}
  .node.current{background:var(--yellow);box-shadow:0 5px 0 #e6a200;animation:bob 1.4s ease-in-out infinite;}
  .node.locked{background:var(--gray);box-shadow:0 5px 0 #c8c8c8;color:#afafaf;cursor:not-allowed;}
  @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
  .node .lbl{position:absolute;bottom:-20px;font-size:11px;color:var(--gray-mid);white-space:nowrap;}
  .node.current .lbl{color:#e6a200;}
  .start-pill{position:absolute;top:-40px;left:50%;transform:translateX(-50%);background:#fff;color:var(--green);border:2px solid var(--gray);padding:5px 12px;border-radius:14px;font-size:12px;box-shadow:0 3px 0 var(--gray);}
  .start-pill::after{content:"";position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);border-left:8px solid transparent;border-right:8px solid transparent;border-top:8px solid #fff;}

  .lesson-body{flex:1;padding:20px 22px;display:flex;flex-direction:column;}
  .prompt-title{font-size:21px;color:var(--gray-dark);margin-bottom:20px;}
  .speaker-row{display:flex;align-items:center;gap:14px;margin-bottom:22px;flex-wrap:wrap;}
  .speaker-btn{background:var(--blue);border:none;box-shadow:0 4px 0 var(--blue-dark);color:#fff;width:66px;height:66px;border-radius:16px;font-size:28px;cursor:pointer;flex-shrink:0;}
  .speaker-btn.small{width:44px;height:44px;font-size:18px;border-radius:12px;}
  .speaker-btn:active{transform:translateY(2px);box-shadow:0 2px 0 var(--blue-dark);}
  .es-word{font-size:23px;color:var(--gray-dark);}

  .choice-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:4px;}
  .choice{position:relative;border:2px solid var(--gray);border-bottom-width:4px;border-radius:16px;padding:18px 12px;background:#fff;cursor:pointer;text-align:center;font-size:17px;color:var(--gray-dark);transition:.1s;}
  .choice .emoji{font-size:38px;display:block;margin-bottom:6px;}
  .choice .num{position:absolute;top:7px;left:11px;font-size:12px;color:var(--gray-mid);}
  .choice:hover{background:#f7fdff;}
  .choice.selected{border-color:var(--blue);background:#ddf4ff;color:var(--blue-dark);}
  .choice.correct{border-color:var(--green);background:var(--green-light);color:var(--green-dark);}
  .choice.wrong{border-color:var(--red);background:#ffdfe0;color:var(--red-dark);}
  .choice.disabled{pointer-events:none;}

  .answer-area{min-height:60px;border-top:2px solid var(--gray);border-bottom:2px solid var(--gray);padding:12px 4px;display:flex;flex-wrap:wrap;gap:8px;align-content:flex-start;margin-bottom:18px;}
  .bank{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;}
  .tile{border:2px solid var(--gray);border-bottom-width:4px;border-radius:14px;background:#fff;padding:10px 15px;font-size:17px;color:var(--gray-dark);cursor:pointer;transition:.08s;}
  .tile:active{transform:translateY(2px);}
  .tile.used{background:var(--gray);border-color:var(--gray);color:var(--gray);pointer-events:none;box-shadow:none;}

  .match-cols{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:4px;}
  .match-btn{border:2px solid var(--gray);border-bottom-width:4px;border-radius:14px;background:#fff;padding:15px 10px;font-size:16px;color:var(--gray-dark);cursor:pointer;transition:.08s;}
  .match-btn.selected{border-color:var(--blue);background:#ddf4ff;color:var(--blue-dark);}
  .match-btn.done{opacity:.25;pointer-events:none;border-color:var(--green);}
  .match-btn.flash-wrong{border-color:var(--red);background:#ffdfe0;}

  .type-input{width:100%;border:2px solid var(--gray);border-radius:14px;padding:15px;font-size:18px;font-family:inherit;font-weight:800;color:var(--gray-dark);outline:none;}
  .type-input:focus{border-color:var(--blue);}

  .footer{padding:16px 22px 26px;border-top:2px solid transparent;transition:.2s;}
  .footer.correct{background:var(--green-light);border-color:#a6e772;}
  .footer.wrong{background:#ffdfe0;border-color:#ffb3b5;}
  .feedback{display:flex;align-items:center;gap:12px;margin-bottom:14px;font-size:18px;}
  .feedback .fico{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;background:#fff;}
  .feedback.correct{color:var(--green-dark);} .feedback.wrong{color:var(--red-dark);}
  .feedback small{display:block;font-size:13px;font-weight:700;}
  .btn{width:100%;border:none;border-radius:16px;padding:15px;font-size:16px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;font-family:inherit;transition:.1s;}
  .btn-green{background:var(--green);color:#fff;box-shadow:0 4px 0 var(--green-dark);}
  .btn-green:active{transform:translateY(2px);box-shadow:0 2px 0 var(--green-dark);}
  .btn-red{background:var(--red);color:#fff;box-shadow:0 4px 0 var(--red-dark);}
  .btn-red:active{transform:translateY(2px);box-shadow:0 2px 0 var(--red-dark);}
  .btn-gray{background:var(--gray);color:var(--gray-mid);box-shadow:none;cursor:not-allowed;}
  .btn-skip{background:none;color:var(--gray-mid);border:2px solid var(--gray);box-shadow:0 4px 0 var(--gray);}

  .complete{align-items:center;justify-content:center;text-align:center;padding:30px;gap:6px;}
  .complete .trophy{font-size:86px;animation:pop .5s ease;}
  @keyframes pop{0%{transform:scale(0)}70%{transform:scale(1.2)}100%{transform:scale(1)}}
  .complete h1{font-size:28px;color:var(--yellow);text-shadow:0 2px 0 #e6a200;}
  .stat-cards{display:flex;gap:12px;margin:20px 0;width:100%;max-width:360px;}
  .stat-card{flex:1;border-radius:16px;padding:2px;}
  .stat-card.gold{background:var(--yellow);} .stat-card.blue{background:var(--blue);}
  .stat-card .inner{background:#fff;border-radius:14px;padding:10px 6px;}
  .stat-card h2{font-size:12px;text-transform:uppercase;letter-spacing:.5px;padding:6px 0 8px;}
  .stat-card.gold h2{color:#ffc800;} .stat-card.blue h2{color:#1cb0f6;}
  .stat-card .val{font-size:21px;color:var(--gray-dark);display:flex;align-items:center;justify-content:center;gap:5px;}

  .modal{position:fixed;inset:0;background:rgba(255,255,255,.96);display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:30px;z-index:20;gap:14px;}
  .modal.active{display:flex;}
  .modal .big{font-size:74px;} .modal h2{font-size:23px;color:var(--red);} .modal p{font-weight:700;color:var(--gray-mid);font-size:15px;max-width:340px;}
  .modal .btn{max-width:320px;}
</style>
</head>
<body>
<div id="app">

  <!-- HOME -->
  <section id="home" class="screen active">
    <div class="topbar">
      <button class="menu-btn" onclick="openReset()" title="Menu">⚙️</button>
      <div style="display:flex;gap:14px;">
        <div class="stat streak"><span class="icon">🔥</span><span id="h-streak">0</span></div>
        <div class="stat gems"><span class="icon">💎</span><span id="h-gems">0</span></div>
        <div class="stat hearts"><span class="icon">❤️</span><span id="h-hearts">5</span></div>
      </div>
    </div>
    <div class="home-header">
      <h1>¡Hola, Tineke! 🇪🇸</h1>
      <p>12 thema's · 30 lessen elk. Kies een les en leg je streak aan.</p>
    </div>
    <div id="units"></div>
  </section>

  <!-- LESSON -->
  <section id="lesson" class="screen">
    <div class="progress-wrap">
      <button class="close-btn" onclick="quitLesson()">✕</button>
      <div class="progress-bar"><div class="progress-fill" id="l-progress"></div></div>
      <div class="stat hearts"><span class="icon">❤️</span><span id="l-hearts">5</span></div>
    </div>
    <div class="lesson-body" id="l-body"></div>
    <div class="footer" id="l-footer">
      <div id="l-feedback"></div>
      <button class="btn btn-gray" id="l-check" disabled onclick="onCheck()">Controleer</button>
    </div>
  </section>

  <!-- COMPLETE -->
  <section id="done" class="screen complete">
    <div class="trophy">🏆</div>
    <h1>¡Bien hecho!</h1>
    <p style="color:var(--gray-mid);font-weight:700">Les voltooid</p>
    <div class="stat-cards">
      <div class="stat-card gold"><div class="inner"><h2>Deze les XP</h2><div class="val">⚡ <span id="d-xp">0</span></div></div></div>
      <div class="stat-card blue"><div class="inner"><h2>Goed</h2><div class="val" id="d-acc">0%</div></div></div>
    </div>
    <button class="btn btn-green" style="max-width:340px" onclick="backHome()">Doorgaan</button>
  </section>

  <!-- OUT OF HEARTS -->
  <div class="modal" id="heartModal">
    <div class="big">💔</div>
    <h2>Je hartjes zijn op!</h2>
    <p>Geen zorgen — van fouten leer je het meest. Hartjes vullen vanzelf aan (1 per 30 min), of vul ze nu bij.</p>
    <button class="btn btn-green" onclick="refillHearts()">❤️ Hartjes aanvullen</button>
    <button class="btn btn-skip" onclick="quitLesson()">Terug naar het overzicht</button>
  </div>

  <!-- RESET / MENU -->
  <div class="modal" id="resetModal">
    <div class="big">⚙️</div>
    <h2 style="color:var(--gray-dark)">Menu</h2>
    <p id="reset-stats"></p>
    <button class="btn btn-green" onclick="closeReset()">Verder leren</button>
    <button class="btn btn-red" onclick="resetAll()">🗑️ Alle voortgang wissen</button>
  </div>

</div>

<script>
/* ============================================================
   DATA  —  12 thema's, compact genoteerd en geparsed
   w:  es | nl | emoji         s:  spaanse woorden = nederlandse zin
   ============================================================ */
const RAW = [
{t:"Unit 1 · De basis",c:"#58cc02",g:"🦉",
 w:`hola|hallo|👋
adiós|tot ziens|👋
